# =============================================================================
# Expensify Data Pipeline — Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is listed in .gitignore.
# =============================================================================

# --- API Settings -----------------------------------------------------------
EXPENSIFY_API_URL=https://integrations.expensify.com/Integration-Server/ExpensifyIntegrations

# Seconds to wait for a response before timing out
EXPENSIFY_TIMEOUT=30

# --- Template Directory -----------------------------------------------------
# Directory containing the three Freemarker templates:
#   reports_template.ftl, transactions_template.ftl, actions_template.ftl
EXPENSIFY_TEMPLATE_DIR=config/templates

# --- Output Folders ---------------------------------------------------------
UPLOAD_PENDING_DIR=uploads/pending
UPLOAD_PROCESSED_DIR=uploads/processed

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
# Log file retention in days. Use 0 to clear existing logs on startup.
LOG_RETENTION_DAYS=30

# --- Cleanup / Retention ----------------------------------------------------
# Number of days to retain processed CSV files before cleanup.py removes them
RETENTION_DAYS=30

# --- PostgreSQL Load Procedure ----------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
# Leave empty (DB_PASSWORD="") if your local PostgreSQL has no password.
DB_PASSWORD=change-me
DB_PROCEDURE=public.proc_load_expensify
DB_CONNECT_TIMEOUT=10
DB_CONNECT_RETRIES=2
DB_CONNECT_RETRY_DELAY_SECONDS=2

# --- Accounts ---------------------------------------------------------------
# Add one numbered block per Expensify account.
# Required keys per account:
#   ACCOUNT_<N>_NAME              — a short slug used as the output subdirectory name
#   ACCOUNT_<N>_PARTNER_USER_ID   — Expensify partner user ID
#   ACCOUNT_<N>_PARTNER_USER_SECRET — Expensify partner user secret
#
# The pipeline scans ACCOUNT_1_*, ACCOUNT_2_*, … in order until a gap is found.

ACCOUNT_1_NAME=demo_account_one
ACCOUNT_1_PARTNER_USER_ID=demo_partner_user_one
ACCOUNT_1_PARTNER_USER_SECRET=demo_secret_one

ACCOUNT_2_NAME=demo_account_two
ACCOUNT_2_PARTNER_USER_ID=demo_partner_user_two
ACCOUNT_2_PARTNER_USER_SECRET=demo_secret_two
