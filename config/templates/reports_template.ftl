</#if><#list reports as report><#assign approvers_json><@toJson (report.approvers![])/></#assign>"${report.reportID}","${(report.oldReportID!"")?replace('"','""')}","${(report.reportName!"")?replace('"','""')}","${(report.accountEmail!"")?replace('"','""')}","${(report.accountID!"")?replace('"','""')}","${(report.status!"")?replace('"','""')}","${(report.displayStatus!"")?replace('"','""')}","${(report.policyName!"")?replace('"','""')}","${(report.policyID!"")?replace('"','""')}","${(report.entryID!"")?replace('"','""')}","${(report.currency!"")}","${((report.total!0)/100)?c}","${(report.submitter.firstName!"")?replace('"','""')}","${(report.submitter.lastName!"")?replace('"','""')}","${(report.submitter.fullName!"")?replace('"','""')}","${(report.managerEmail!"")?replace('"','""')}","${(report.managerUserID!"")?replace('"','""')}","${(report.managerPayrollID!"")?replace('"','""')}","${(report.manager.firstName!"")?replace('"','""')}","${(report.manager.lastName!"")?replace('"','""')}","${(report.manager.fullName!"")?replace('"','""')}","${(report.employeeCustomField1!"")?replace('"','""')}","${(report.employeeCustomField2!"")?replace('"','""')}","${(report.created!"")}","${(report.submitted!"")}","${(report.approved!"")}","${(report.reimbursed!"")}","${(report.isACHReimbursed!false)?string('true','false')}","${approvers_json?replace('"','""')}"
