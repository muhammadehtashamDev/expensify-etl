# =============================================================================
# Expensify Data Pipeline — .gitignore
# =============================================================================

# Environment / secrets
.env
*.env.local
config/accounts.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs (keep directory, ignore content)
logs/*.log
logs/*.log.*

# Upload data (never commit export data)
uploads/pending/
uploads/processed/

# Coverage
.coverage
htmlcov/
coverage.xml
